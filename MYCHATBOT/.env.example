# LLM 제공자 선택: "openai" 또는 "ollama"
LLM_PROVIDER=openai

# OpenAI (LLM_PROVIDER=openai 일 때)
OPENAI_API_KEY=sk-여기에_API_키_입력
OPENAI_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# Ollama (LLM_PROVIDER=ollama 일 때, 보안 필요한 경우)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# 문서 경로 (Obsidian 볼트 or 마크다운 폴더)
DOCS_PATH=./docs

# 청크 설정
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# VectorDB
CHROMA_DIR=./chroma_db
COLLECTION_NAME=mychatbot

# 참고할 문서 조각 수
RETRIEVER_K=4
